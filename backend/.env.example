# OpenAI (default for demo)
OPENAI_API_KEY=your-key-here
MODEL=gpt-5.4-mini

# NCBI API key — bumps PubMed rate limit from 3 to 10 req/sec
# Free at https://account.ncbi.nlm.nih.gov/settings/
NCBI_API_KEY=

# To use local Ollama instead, swap ChatOpenAI for ChatOllama in api/app.py and set:
# MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://localhost:11434
